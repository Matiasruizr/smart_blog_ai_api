# ── Core ──────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-use-a-long-random-string-minimum-64-chars
ALLOWED_ORIGINS=http://localhost:3000
API_V1_PREFIX=/api/v1
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Owner credentials ──────────────────────────────────────────────────────────
# Generate password hash:  python -c "from app.core.security import hash_password; print(hash_password('yourpassword'))"
OWNER_USERNAME=admin
OWNER_PASSWORD_HASH=$2b$12$...

# ── Database ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=smart_blog_ai

# ── AI (Anthropic) ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=4096

# ── Cover image providers (Unsplash → Pexels fallback) ────────────────────────
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# ── Email ──────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=smtp                  # smtp | sendgrid
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_TO_OWNER=you@yourdomain.com

# SMTP (used when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password

# SendGrid (used when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=SG.xxx

# ── LinkedIn ───────────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/v1/linkedin/callback
LINKEDIN_SCOPE=r_liteprofile w_member_social

# ── URLs ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BLOG_URL=http://localhost:3000
API_URL=http://localhost:8000

# ── Automation Scheduler ───────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
AUTOMATION_INTERVAL_HOURS=48
